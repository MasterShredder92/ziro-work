NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SOURCE_SUPABASE_URL=
SOURCE_SUPABASE_SERVICE_ROLE_KEY=
TARGET_SUPABASE_URL=
TARGET_SUPABASE_SERVICE_ROLE_KEY=
# When 1, server-side getServiceClient() uses TARGET_* (see src/lib/supabase.ts). Use if
# NEXT_PUBLIC_* still points at an old project but CRM data lives on TARGET_*.
ZIRO_SERVER_USE_TARGET_SUPABASE=
# Optional: Supabase dashboard personal access token (apply generated SQL via Management API)
SUPABASE_ACCESS_TOKEN=
SYNC_DRY_RUN=true
SYNC_STRICT_TABLES=false
ANTHROPIC_API_KEY=

# Square Integration
# Get these from your Square Developer Dashboard: https://developer.squareup.com/apps
SQUARE_APP_ID=sq0idp-your_app_id_here
SQUARE_APP_SECRET=sq0csp-your_app_secret_here
SQUARE_ACCESS_TOKEN=your_square_access_token_here
# Signing key for the bookings webhook — required in production; code reads this exact name
SQUARE_BOOKINGS_WEBHOOK_SIGNATURE_KEY=your_bookings_webhook_signature_key_here

# Stripe
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here

# App
NEXT_PUBLIC_APP_URL=https://your-app-url.vercel.app
# Default tenant ID for single-tenant deployments
NEXT_PUBLIC_ZIRO_DEFAULT_TENANT_ID=your_tenant_uuid_here

# Session fallback — set to 0 in production to disable the service-client fallback session.
# Production default is fail-closed regardless, but this flag also disables it in dev/test.
ZIRO_SESSION_FALLBACK=0
